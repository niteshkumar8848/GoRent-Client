# GoRent Backend Environment Variables
# Local Development Configuration

# MongoDB - Use local MongoDB or Atlas connection string
# For local: mongodb://localhost:27017/gorent
# For Atlas: mongodb+srv://<username>:<password>@cluster.mongodb.net/gorent
MONGO_URI=mongodb://localhost:27017/gorent

# JWT Secret - Change this to a secure random string in production
JWT_SECRET=gorent_dev_secret_key_2024_change_in_production

# Server Configuration
PORT=5000
NODE_ENV=development

# CORS - Allowed origins (comma-separated)
# For development, we allow all origins
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Admin Secret (for reset endpoint in development)
ADMIN_SECRET=gorent-admin-reset

# Optional: ImageKit Configuration (uncomment and fill if needed)
# IMAGEKIT_PUBLIC_KEY=your_public_key
# IMAGEKIT_PRIVATE_KEY=your_private_key
# IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_imagekit_id

